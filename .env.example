# Anthropic Claude API
ANTHROPIC_API_KEY=sk-ant-your-key-here
# Optional: override model name (default: claude-sonnet-4-6)
# Options: claude-opus-4-6 | claude-sonnet-4-6 | claude-haiku-4-5
# ANTHROPIC_MODEL=claude-sonnet-4-6

# Tavily Web Search API
TAVILY_API_KEY=tvly-your-key-here

# SMTP (Beispiel: Gmail mit App-Passwort)
# Gmail: Google-Konto → Sicherheit → 2FA aktivieren → App-Passwörter erstellen
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=deine@gmail.com
SMTP_PASS=dein-app-passwort
SMTP_FROM=deine@gmail.com

# Server Port
PORT=3270
